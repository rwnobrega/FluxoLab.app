Variáveis
    segredo, palpite: número
    tentativas: número
Início
    segredo = rand_int(1, 100)
    tentativas = 0
    Faça
        Escreva "Entre com um palpite:"
        Leia palpite
        tentativas = tentativas + 1
        Se segredo > palpite
            Escreva "O segredo é maior"
        SenãoSe segredo < palpite
            Escreva "O segredo é menor"
        FimSe
    enquanto segredo != palpite
    Escreva "Parabéns! Você acertou em ", tentativas, " tentativas"
Fim
